# Jobseeker Automation Platform
# Environment Configuration
# Copy this file to .env and adjust values

# ============================================================
# Model Configuration
# ============================================================
VLLM_MODEL_NAME=fdtn-ai/Foundation-Sec-8B-Reasoning
VLLM_QUANTIZATION=awq
VLLM_MAX_MODEL_LEN=4096
VLLM_GPU_MEMORY_UTILIZATION=0.7
VLLM_ENFORCE_EAGER=true
VLLM_HOST=vllm-engine
VLLM_PORT=8000

# Embedding model
EMBEDDING_MODEL_NAME=mixedbread-ai/mxbai-embed-large-v1
EMBEDDING_DEVICE=cuda

# ============================================================
# Qdrant Configuration
# ============================================================
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION_JOBS=job_descriptions
QDRANT_COLLECTION_RESUMES=resumes
QDRANT_VECTOR_SIZE=1024

# ============================================================
# Redis / Celery Configuration
# ============================================================
REDIS_HOST=redis
REDIS_PORT=6379
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ============================================================
# Scraper Configuration
# ============================================================
SCRAPER_SCHEDULE_HOURS=6
SCRAPER_MAX_JOBS_PER_SOURCE=50
SCRAPER_SOURCES=indeed,linkedin,dice

# ============================================================
# API / Orchestrator
# ============================================================
API_HOST=0.0.0.0
API_PORT=8001

# ============================================================
# Streamlit
# ============================================================
STREAMLIT_PORT=8501
STREAMLIT_HOST=0.0.0.0

# ============================================================
# Playwright
# ============================================================
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=30000
PLAYWRIGHT_STEALTH_ENABLED=true
